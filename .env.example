# ============================================================
# Temus Tools — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.
# ============================================================


# ------------------------------------------------------------
# GitLab (Self-hosted)
# ------------------------------------------------------------

# Your GitLab server address (no trailing slash)
GITLAB_URL=https://gitlab.yourcompany.com

# Personal Access Token with api + write_repository scopes
# Create at: GitLab → User Settings → Access Tokens
GITLAB_TOKEN=your-gitlab-personal-access-token

# Your GitLab username
GITLAB_USERNAME=your-username


# ------------------------------------------------------------
# AWS Credentials
# ------------------------------------------------------------

# IAM user with S3 + CloudFront permissions
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-1


# ------------------------------------------------------------
# AWS — DEV Environment
# ------------------------------------------------------------

AWS_S3_BUCKET_DEV=your-dev-bucket-name
AWS_CLOUDFRONT_ID_DEV=your-dev-cloudfront-distribution-id
AWS_CLOUDFRONT_URL_DEV=https://dev.yourproject.com


# ------------------------------------------------------------
# AWS — UAT Environment
# ------------------------------------------------------------

AWS_S3_BUCKET_UAT=your-uat-bucket-name
AWS_CLOUDFRONT_ID_UAT=your-uat-cloudfront-distribution-id
AWS_CLOUDFRONT_URL_UAT=https://uat.yourproject.com
